# Copy this file to .env and replace production values before deploy.
# Comments must stay on their own line; inline comments can become part of the value.
# Empty uncommented values are required in production.
# Commented values are optional overrides with safe code defaults.
# Variables are grouped by concern and alphabetized within each block.

# Django
# Comma-separated hostnames allowed to serve this site.
ALLOWED_HOSTS=localhost,127.0.0.1,{{ cookiecutter.domain_name }}
# Comma-separated HTTPS origins allowed for unsafe CSRF-protected requests.
CSRF_TRUSTED_ORIGINS=https://{{ cookiecutter.domain_name }},https://www.{{ cookiecutter.domain_name }}
# Runtime settings overlay to load: dev, ci, or prod.
DJANGO_ENV=dev
# Python logging level.
LOG_LEVEL=INFO
# Replace with a securely generated secret before production deploy.
SECRET_KEY=django-insecure-change-me-in-production

# Database/PostgreSQL
# Optional Django persistent connection lifetime in seconds.
# CONN_MAX_AGE=60
# Django database URL used by the app.
DATABASE_URL=postgres://{{ cookiecutter.project_slug.replace('-', '_') }}:{{ cookiecutter.project_slug.replace('-', '_') }}@postgres:5432/{{ cookiecutter.project_slug.replace('-', '_') }}
# PostgreSQL database created by the Compose service.
POSTGRES_DB={{ cookiecutter.project_slug.replace('-', '_') }}
# PostgreSQL password used by the Compose service; replace before production deploy.
POSTGRES_PASSWORD={{ cookiecutter.project_slug.replace('-', '_') }}
# PostgreSQL user used by the Compose service.
POSTGRES_USER={{ cookiecutter.project_slug.replace('-', '_') }}

# Release
# Release image tag the prod stack runs; deploys and rollbacks repoint this.
# The v-prefixed tag of a published release.
# APP_VERSION=v0.1.0
{%- if cookiecutter.use_celery != "none" %}

# Cache and broker/Redis
{%- else %}

# Cache/Redis
{%- endif %}
# Django cache URL.
CACHE_URL=rediscache://redis:6379/0
{%- if cookiecutter.use_celery != "none" %}
# Celery broker URL.
CELERY_BROKER_URL=redis://redis:6379/1
{%- endif %}

# Process sizing
{%- if cookiecutter.use_celery != "none" %}
# Celery worker child process count.
CELERY_WORKER_CONCURRENCY=2
# Celery worker task recycle limit per child process.
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
{%- endif %}
# Gunicorn graceful shutdown timeout in seconds.
GUNICORN_GRACEFUL_TIMEOUT=30
# Gunicorn request timeout in seconds.
GUNICORN_TIMEOUT=60
# Gunicorn worker process count.
GUNICORN_WORKERS=5
{%- if cookiecutter.redis == "compose" %}
# Redis memory ceiling; writes are rejected at the cap (noeviction).
REDIS_MAXMEMORY=256mb
{%- endif %}
{%- if cookiecutter.use_traefik == "yes" %}

# Reverse proxy
{%- if cookiecutter.traefik_tls == "letsencrypt" %}
# ACME registration email used by Traefik.
TRAEFIK_ACME_EMAIL={{ cookiecutter.author_email }}
{%- endif %}
# Public hostname routed by Traefik.
TRAEFIK_DOMAIN={{ cookiecutter.domain_name }}
{%- endif %}
{%- if cookiecutter.email_provider != "none" %}

# Email
# Sender address for outgoing mail.
DEFAULT_FROM_EMAIL=noreply@{{ cookiecutter.domain_name }}
{%- if cookiecutter.email_provider == "resend" %}
# Resend API key required in production.
RESEND_API_KEY=
{%- else %}
# SMTP relay hostname required in production.
EMAIL_HOST=
# Optional SMTP password.
# EMAIL_HOST_PASSWORD=change-me
# Optional SMTP user.
# EMAIL_HOST_USER=postmaster@example.com
# Optional SMTP port.
# EMAIL_PORT=587
# Optional STARTTLS toggle.
# EMAIL_USE_TLS=True
{%- endif %}
{%- endif %}
{%- if cookiecutter.use_sentry == "yes" %}

# Observability/Sentry
# Sentry DSN required in production.
SENTRY_DSN=
# Optional Sentry log event capture.
# SENTRY_ENABLE_LOGS=False
# Optional Sentry profiling session sample rate from 0.0 to 1.0.
# SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
# Optional Sentry tracing sample rate from 0.0 to 1.0.
# SENTRY_TRACES_SAMPLE_RATE=1.0
{%- endif %}
{%- if cookiecutter.use_s3_media == "yes" %}

# Object storage/S3-compatible
# Optional explicit AWS access key.
# AWS_ACCESS_KEY_ID=AKIA...
# Optional custom CDN or bucket domain.
# AWS_S3_CUSTOM_DOMAIN=media.example.com
# Optional S3-compatible endpoint URL.
# AWS_S3_ENDPOINT_URL=https://s3.example.com
# Optional AWS region.
# AWS_S3_REGION_NAME=eu-west-1
# Optional explicit AWS secret key.
# AWS_SECRET_ACCESS_KEY=change-me
# S3-compatible bucket name required in production.
AWS_STORAGE_BUCKET_NAME=
{%- endif %}
